{
  "entities": {
    "Analysis": {
      "title": "Electrical Analysis",
      "description": "Represents a completed electrical blueprint analysis result",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner UID" },
        "fileName": { "type": "string", "description": "Original file name" },
        "report": { "type": "string", "description": "Markdown content of the analysis" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "status": { "type": "string", "enum": ["completed", "failed"] }
      },
      "required": ["userId", "fileName", "report", "timestamp", "status"]
    }
  },
  "firestore": {
    "analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Collection of electrical blueprint analyses"
    }
  }
}
