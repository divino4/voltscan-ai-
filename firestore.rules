rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Analysis Entity
    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'fileName', 'report', 'timestamp', 'status'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.fileName is string && data.fileName.size() <= 256
        && data.report is string && data.report.size() <= 1048576 // 1MB limit for markdown
        && data.timestamp == request.time
        && data.status in ['completed', 'failed'];
    }

    match /analyses/{analysisId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(analysisId)
        && isValidAnalysis(incoming());
        
      allow update: if false; // Reports are immutable for now
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
